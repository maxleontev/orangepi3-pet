#!/bin/bash


echo "rm"
rm  core-image-base-orange-pi-3lts.rootfs-2026*.wic*

echo "cp"
cp ../build-orangepi3/tmp/deploy/images/orange-pi-3lts/core-image-base-orange-pi-3lts.rootfs-2026*.wic.gz .

echo "gunzip"
gunzip  core-image-base-orange-pi-3lts.rootfs-2026*.wic.gz

echo "dd"
sudo dd if=$(ls core-image-base-orange-pi-3lts.rootfs-2026*.wic) of=/dev/sda bs=4M status=progress

echo "sync"
sync

echo "rm"
rm  core-image-base-orange-pi-3lts.rootfs-2026*.wic*

echo "done"
